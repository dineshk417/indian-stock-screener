# ── NiftyEdge — Streamlit Secrets Template ────────────────────────────────────────────
# Copy this file to .streamlit/secrets.toml and fill in your real values.
# .streamlit/secrets.toml is gitignored — never commit real credentials.
#
# In Streamlit Cloud: App Settings → Secrets → paste the content below.

# ── Google OAuth 2.0 ────────────────────────────────────────────────────────────────
# Steps:
#   1. Go to https://console.cloud.google.com → APIs & Services → Credentials
#   2. Create OAuth 2.0 Client ID (Web application)
#   3. Authorized redirect URI: https://<your-app>.streamlit.app/oauth2callback
#   4. Copy client_id and client_secret below
#   5. Generate a random cookie_secret: python -c "import secrets; print(secrets.token_hex(32))"

[auth]
redirect_uri  = "https://stockscreener4.streamlit.app/oauth2callback"
cookie_secret = "REPLACE_WITH_RANDOM_32_CHAR_HEX_STRING"

[auth.google]
client_id     = "REPLACE_WITH_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
client_secret = "REPLACE_WITH_GOOGLE_CLIENT_SECRET"

# ── Database (Supabase / any PostgreSQL) ────────────────────────────────────────────
# Leave blank to use local SQLite (fine for dev, data doesn't persist on Cloud).
DATABASE_URL = "postgresql://user:password@host:5432/dbname"

# ── Admin ───────────────────────────────────────────────────────────────────────────
# The email address that can access the /Users admin page.
# Leave blank to allow any logged-in user to see the user list.
ADMIN_EMAIL = "your@email.com"

# ── Telegram (optional) ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN  = "your_bot_token"
TELEGRAM_CHANNEL_ID = "@your_channel"

# ── Anthropic / Claude API ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY = "sk-ant-..."
